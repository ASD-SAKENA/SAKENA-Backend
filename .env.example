# Copy this file to `.env` and adjust as needed. `.env` is git-ignored.
# docker-compose reads these automatically.

# --- Database ---
DB_NAME=sakena
DB_USERNAME=sakena
DB_PASSWORD=sakena
DB_PORT=5432

# JDBC URL used by the app. For local (app on host, db in Docker) keep localhost.
# docker-compose overrides this to point at the `db` service automatically.
DB_URL=jdbc:postgresql://localhost:5432/sakena

# --- Application ---
SERVER_PORT=8080
LOG_LEVEL_APP=DEBUG

# Origin of the frontend app. Used for CORS (allowed origin) and for the
# password-reset email link. Set to the real frontend URL in production.
FRONTEND_URL=http://localhost:3000
